generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/desktop-prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                      @id @default(cuid())
  email                  String                      @unique
  passwordHash           String
  fullName               String
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  memberships            CompanyMembership[]
  createdDocs            Document[]                  @relation("DocumentCreatedBy")
  paymentsCreated        Payment[]                   @relation("PaymentCreatedBy")
  eventsCreated          DocumentStatusEvent[]       @relation("StatusEventCreatedBy")
  notificationReads      NotificationRead[]
  submittedPaymentProofs PaymentProof[]              @relation("PaymentProofSubmittedBy")
  reviewedPaymentProofs  PaymentProof[]              @relation("PaymentProofReviewedBy")
  companyStatusEvents    CompanyAccountStatusEvent[] @relation("CompanyStatusEventActor")
  reclamationsCreated    Reclamation[]               @relation("ReclamationCreatedByUser")
  reclamationMessages    ReclamationMessage[]        @relation("ReclamationMessageAuthorUser")
}

model Company {
  id                   String                      @id @default(cuid())
  name                 String
  slug                 String                      @unique
  defaultCurrency      String                      @default("MAD")
  accountStatus        String                      @default("ACTIVE_PAID")
  trialStartedAt       DateTime?
  trialEndsAt          DateTime?
  graceEndsAt          DateTime?
  awaitingActivationAt DateTime?
  activatedAt          DateTime?
  lockedAt             DateTime?
  lockReason           String?
  statusNote           String?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  memberships          CompanyMembership[]
  profile              CompanyProfile?
  numberingRules       NumberingSequence[]
  clients              Client[]
  products             Product[]
  documents            Document[]
  templates            Template[]
  exports              ExportJob[]
  imports              ImportJob[]
  paymentAllocations   PaymentAllocation[]
  payments             Payment[]
  notificationRules    NotificationRule[]
  notificationEvents   NotificationEvent[]
  settings             CompanySetting[]
  documentPayloads     DocumentTypePayload[]
  documentLineItems    DocumentLineItem[]
  documentRelations    DocumentRelation[]
  documentStatusEvents DocumentStatusEvent[]
  documentAttachments  DocumentAttachment[]
  templateVersions     TemplateVersion[]
  importResults        ImportJobResult[]
  paymentProofs        PaymentProof[]
  accountStatusEvents  CompanyAccountStatusEvent[]
  subscriptions        CompanySubscription[]
  reclamations         Reclamation[]
  PlatformAuditLog     PlatformAuditLog[]
}

model CompanyMembership {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  role      String   @default("OWNER")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([userId, isActive])
}

model CompanyProfile {
  id             String   @id @default(cuid())
  companyId      String   @unique
  legalName      String?
  ice            String?
  ifNumber       String?
  rcNumber       String?
  cnssNumber     String?
  phoneFix       String?
  phoneMobile    String?
  email          String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  country        String?
  zipCode        String?
  bankName       String?
  iban           String?
  swift          String?
  taxRateDefault Decimal?
  website        String?
  logoUrl        String?
  signatureUrl   String?
  extraJson      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model NumberingSequence {
  id           String   @id @default(cuid())
  companyId    String
  documentType String
  prefix       String   @default("")
  format       String   @default("{prefix}-{year}-{seq:5}")
  nextValue    Int      @default(1)
  resetYearly  Boolean  @default(true)
  currentYear  Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, documentType])
}

model Client {
  id        String     @id @default(cuid())
  companyId String
  code      String?
  name      String
  email     String?
  phone     String?
  phoneFix  String?
  address   String?
  city      String?
  country   String?
  ice       String?
  ifNumber  String?
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  documents Document[]
  payments  Payment[]

  @@index([companyId, name])
  @@index([companyId, email])
}

model Product {
  id          String             @id @default(cuid())
  companyId   String
  sku         String?
  name        String
  description String?
  unit        String             @default("u")
  priceHT     Decimal
  vatRate     Decimal            @default(20)
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lineItems   DocumentLineItem[]

  @@unique([companyId, sku])
  @@index([companyId, name])
}

model Document {
  id                 String                @id @default(cuid())
  companyId          String
  createdById        String
  clientId           String?
  documentType       String
  documentNumber     String
  status             String                @default("DRAFT")
  title              String?
  issueDate          DateTime?
  dueDate            DateTime?
  language           String                @default("fr")
  currency           String                @default("MAD")
  subtotalHT         Decimal               @default(0)
  totalTax           Decimal               @default(0)
  totalTTC           Decimal               @default(0)
  amountPaid         Decimal               @default(0)
  amountDue          Decimal               @default(0)
  notes              String?
  terms              String?
  metadataJson       String?
  convertedFromId    String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  company            Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy          User                  @relation("DocumentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  client             Client?               @relation(fields: [clientId], references: [id], onDelete: SetNull)
  payload            DocumentTypePayload?
  lineItems          DocumentLineItem[]
  sourceRelations    DocumentRelation[]    @relation("SourceDocument")
  targetRelations    DocumentRelation[]    @relation("TargetDocument")
  statusEvents       DocumentStatusEvent[]
  attachments        DocumentAttachment[]
  exports            ExportJob[]
  paymentAllocations PaymentAllocation[]
  notificationEvents NotificationEvent[]

  @@unique([companyId, documentType, documentNumber])
  @@index([companyId, status, dueDate])
  @@index([companyId, clientId, createdAt])
}

model DocumentTypePayload {
  id          String   @id @default(cuid())
  companyId   String
  documentId  String   @unique
  payloadJson String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model DocumentLineItem {
  id             String   @id @default(cuid())
  companyId      String
  documentId     String
  productId      String?
  sortOrder      Int      @default(0)
  label          String
  description    String?
  sku            String?
  unit           String   @default("u")
  quantity       Decimal
  unitPriceHT    Decimal
  discountRate   Decimal  @default(0)
  vatRate        Decimal
  lineSubtotalHT Decimal
  lineTotalTTC   Decimal
  snapshotJson   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  document       Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  product        Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([companyId, documentId, sortOrder])
}

model DocumentRelation {
  id               String   @id @default(cuid())
  companyId        String
  sourceDocumentId String
  targetDocumentId String
  relationType     String   @default("CONVERTED")
  mappingJson      String?
  createdAt        DateTime @default(now())
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sourceDocument   Document @relation("SourceDocument", fields: [sourceDocumentId], references: [id], onDelete: Cascade)
  targetDocument   Document @relation("TargetDocument", fields: [targetDocumentId], references: [id], onDelete: Cascade)

  @@index([companyId, sourceDocumentId])
  @@index([companyId, targetDocumentId])
}

model DocumentStatusEvent {
  id         String   @id @default(cuid())
  companyId  String
  documentId String
  actorId    String?
  fromStatus String?
  toStatus   String
  note       String?
  createdAt  DateTime @default(now())
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  actor      User?    @relation("StatusEventCreatedBy", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([companyId, documentId, createdAt])
}

model DocumentAttachment {
  id         String   @id @default(cuid())
  companyId  String
  documentId String
  fileName   String
  mimeType   String
  filePath   String
  fileSize   Int?
  createdAt  DateTime @default(now())
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([companyId, documentId])
}

model Template {
  id             String            @id @default(cuid())
  companyId      String
  documentType   String
  name           String
  description    String?
  templateFormat String
  isDefault      Boolean           @default(false)
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  company        Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  versions       TemplateVersion[]
  exports        ExportJob[]

  @@index([companyId, documentType, isDefault])
  @@index([companyId, name])
}

model TemplateVersion {
  id            String   @id @default(cuid())
  companyId     String
  templateId    String
  versionNumber Int
  engineName    String
  sourcePath    String?
  sourceJson    String?
  configJson    String?
  variablesJson String?
  isPublished   Boolean  @default(true)
  createdAt     DateTime @default(now())
  template      Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([templateId, versionNumber])
  @@index([companyId, templateId])
}

model ExportJob {
  id                String    @id @default(cuid())
  companyId         String
  documentId        String
  templateId        String?
  templateVersionId String?
  exportFormat      String
  status            String    @default("PENDING")
  outputPath        String?
  errorMessage      String?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  document          Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  template          Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([companyId, status, createdAt])
  @@index([companyId, documentId])
}

model ImportJob {
  id             String            @id @default(cuid())
  companyId      String
  createdById    String
  importType     String
  sourceFileName String
  sourceFilePath String
  status         String            @default("PENDING")
  errorMessage   String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  company        Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  results        ImportJobResult[]

  @@index([companyId, status, createdAt])
}

model ImportJobResult {
  id              String    @id @default(cuid())
  companyId       String
  importJobId     String
  extractedType   String?
  confidenceScore Decimal?
  extractedJson   String
  normalizedJson  String?
  warningJson     String?
  createdAt       DateTime  @default(now())
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  importJob       ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([companyId, importJobId])
}

model Payment {
  id          String              @id @default(cuid())
  companyId   String
  clientId    String
  createdById String
  paymentDate DateTime
  amount      Decimal
  method      String
  reference   String?
  notes       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client      Client              @relation(fields: [clientId], references: [id], onDelete: Restrict)
  createdBy   User                @relation("PaymentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  allocations PaymentAllocation[]

  @@index([companyId, clientId, paymentDate])
}

model PaymentAllocation {
  id              String   @id @default(cuid())
  companyId       String
  paymentId       String
  documentId      String
  amountAllocated Decimal
  createdAt       DateTime @default(now())
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payment         Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  document        Document @relation(fields: [documentId], references: [id], onDelete: Restrict)

  @@unique([paymentId, documentId])
  @@index([companyId, documentId])
}

model PaymentProof {
  id            String    @id @default(cuid())
  companyId     String
  submittedById String
  reviewedById  String?
  method        String
  status        String    @default("SUBMITTED")
  amount        Decimal?
  currency      String    @default("MAD")
  reference     String?
  proofFilePath String?
  note          String?
  reviewNote    String?
  metadataJson  String?
  submittedAt   DateTime  @default(now())
  reviewedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  submittedBy   User      @relation("PaymentProofSubmittedBy", fields: [submittedById], references: [id], onDelete: Restrict)
  reviewedBy    User?     @relation("PaymentProofReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([companyId, status, submittedAt])
  @@index([companyId, submittedById, createdAt])
}

model CompanyAccountStatusEvent {
  id           String   @id @default(cuid())
  companyId    String
  actorId      String?
  fromStatus   String?
  toStatus     String
  reason       String?
  metadataJson String?
  createdAt    DateTime @default(now())
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actor        User?    @relation("CompanyStatusEventActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([companyId, toStatus, createdAt])
}

model NotificationRule {
  id               String   @id @default(cuid())
  companyId        String
  isEnabled        Boolean  @default(true)
  notificationType String
  channel          String   @default("EMAIL")
  daysBeforeDue    Int?
  daysAfterDue     Int?
  sendTime         String   @default("09:00")
  templateSubject  String?
  templateBody     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, isEnabled])
}

model NotificationEvent {
  id               String             @id @default(cuid())
  companyId        String
  documentId       String
  notificationType String
  channel          String
  status           String             @default("PENDING")
  eventKey         String?
  recipient        String?
  title            String?
  body             String?
  actionPath       String?
  metadataJson     String?
  sentAt           DateTime?
  errorMessage     String?
  createdAt        DateTime           @default(now())
  company          Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  document         Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  reads            NotificationRead[]

  @@unique([companyId, eventKey])
  @@index([companyId, status, createdAt])
  @@index([companyId, documentId])
}

model NotificationRead {
  id                  String            @id @default(cuid())
  notificationEventId String
  userId              String
  readAt              DateTime          @default(now())
  event               NotificationEvent @relation(fields: [notificationEventId], references: [id], onDelete: Cascade)
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationEventId, userId])
  @@index([userId, readAt])
}

model CompanySetting {
  id        String   @id @default(cuid())
  companyId String
  key       String
  valueJson String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, key])
}

model PlatformUser {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  fullName            String
  role                String
  isActive            Boolean              @default(true)
  lastLoginAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  sessions            PlatformSession[]
  mfaSecrets          PlatformMfaSecret[]
  auditLogs           PlatformAuditLog[]   @relation("PlatformAuditActor")
  assignedReclaims    Reclamation[]        @relation("ReclamationAssignedPlatformUser")
  reclamationMessages ReclamationMessage[] @relation("ReclamationMessageAuthorPlatformUser")
}

model PlatformSession {
  id           String       @id @default(cuid())
  userId       String
  tokenHash    String       @unique
  expiresAt    DateTime
  lastUsedAt   DateTime?
  ipAddress    String?
  userAgent    String?
  revokedAt    DateTime?
  revokeReason String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  user         PlatformUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([revokedAt])
}

model PlatformMfaSecret {
  id              String       @id @default(cuid())
  userId          String
  secretEncrypted String
  backupCodesHash String?
  isPrimary       Boolean      @default(false)
  verifiedAt      DateTime?
  lastUsedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  user            PlatformUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isPrimary])
}

model PlatformAuditLog {
  id           String        @id @default(cuid())
  actorId      String?
  action       String
  entityType   String
  entityId     String?
  companyId    String?
  metadataJson String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime      @default(now())
  actor        PlatformUser? @relation("PlatformAuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  company      Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt])
  @@index([companyId, createdAt])
  @@index([entityType, entityId])
}

model PlanDefinition {
  id            String                @id @default(cuid())
  code          String                @unique
  name          String
  description   String?
  monthlyPrice  Decimal               @default(0)
  yearlyPrice   Decimal               @default(0)
  currency      String                @default("MAD")
  isActive      Boolean               @default(true)
  metadataJson  String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  limits        PlanLimit[]
  subscriptions CompanySubscription[]

  @@index([isActive])
}

model PlanLimit {
  id           String         @id @default(cuid())
  planId       String
  key          String
  valueInt     Int?
  valueDecimal Decimal?
  valueText    String?
  isUnlimited  Boolean        @default(false)
  metadataJson String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  plan         PlanDefinition @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, key])
  @@index([key])
}

model CompanySubscription {
  id                 String         @id @default(cuid())
  companyId          String
  planId             String
  status             String         @default("TRIAL")
  billingCycle       String         @default("MONTHLY")
  priceAmount        Decimal        @default(0)
  currency           String         @default("MAD")
  startedAt          DateTime       @default(now())
  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  canceledAt         DateTime?
  metadataJson       String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  company            Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan               PlanDefinition @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([companyId, status])
  @@index([planId, status])
  @@index([currentPeriodEnd])
}

model Reclamation {
  id              String               @id @default(cuid())
  companyId       String
  createdByUserId String?
  assignedToId    String?
  status          String               @default("OPEN")
  priority        String               @default("MEDIUM")
  category        String?
  subject         String
  description     String?
  channel         String?
  slaDeadlineAt   DateTime?
  firstResponseAt DateTime?
  resolvedAt      DateTime?
  closedAt        DateTime?
  metadataJson    String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  company         Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUser   User?                @relation("ReclamationCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  assignedTo      PlatformUser?        @relation("ReclamationAssignedPlatformUser", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages        ReclamationMessage[]

  @@index([companyId, status, priority, createdAt])
  @@index([assignedToId, status, updatedAt])
}

model ReclamationMessage {
  id                   String        @id @default(cuid())
  reclamationId        String
  authorType           String
  authorUserId         String?
  authorPlatformUserId String?
  body                 String
  attachmentsJson      String?
  isInternalNote       Boolean       @default(false)
  createdAt            DateTime      @default(now())
  reclamation          Reclamation   @relation(fields: [reclamationId], references: [id], onDelete: Cascade)
  authorUser           User?         @relation("ReclamationMessageAuthorUser", fields: [authorUserId], references: [id], onDelete: SetNull)
  authorPlatformUser   PlatformUser? @relation("ReclamationMessageAuthorPlatformUser", fields: [authorPlatformUserId], references: [id], onDelete: SetNull)

  @@index([reclamationId, createdAt])
  @@index([authorUserId, createdAt])
  @@index([authorPlatformUserId, createdAt])
}
